{
  "name": "sparky",
  "version": "2.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm",
  "scripts": {
    "start": "vite",
    "test": "vitest run",
    "coverage": "pnpm test -- --coverage",
    "mutate": "stryker run",
    "preview": "vite preview",
    "build": "pnpm paraglide:compile && tsc && vite build",
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "pnpm lint:ts && pnpm prettier && pnpm lint:md",
    "lint:ts": "eslint .",
    "lint:md": "markdownlint-cli2 .",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "paraglide:machine-translate": "inlang machine translate --project project.inlang"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alephtwo/sparky.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alephtwo/sparky/issues"
  },
  "homepage": "https://github.com/alephtwo/sparky#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@inlang/cli": "3.1.10",
    "@inlang/paraglide-js": "2.17.0",
    "@solidjs/testing-library": "0.8.10",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.6.0",
    "daisyui": "5.5.19",
    "eslint": "10.2.1",
    "fast-check": "4.7.0",
    "jsdom": "29.1.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@tabler/icons-solidjs": "3.41.1",
    "solid-js": "1.9.12"
  }
}
