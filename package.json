  "repository": {
    "type": "git",
    "url": "git+https://github.com/alephtwo/sparky.git"
  },
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "test": "vitest run",
    "coverage": "pnpm test -- --coverage",
    "mutate": "stryker run",
    "preview": "vite preview",
    "build": "pnpm paraglide:compile && tsc && vite build",
    "oxfmt": "oxfmt --check .",
    "format": "oxfmt --write .",
    "lint": "pnpm lint:ts && pnpm oxfmt && pnpm lint:md",
    "lint:ts": "oxlint .",
    "lint:md": "markdownlint-cli2 .",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "paraglide:machine-translate": "inlang machine translate --project project.inlang"
  },
  "dependencies": {
    "@tabler/icons-solidjs": "3.44.0",
    "oxlint-tsgolint": "0.23.0",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@inlang/cli": "3.1.14",
    "@inlang/paraglide-js": "2.20.2",
    "@solidjs/testing-library": "0.8.10",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "26.0.1",
    "daisyui": "5.6.3",
    "fast-check": "4.8.0",
    "jsdom": "29.1.1",
    "markdownlint": "0.41.0",
    "markdownlint-cli2": "0.22.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.9"
  }
}
