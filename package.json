    "@stryker-mutator/vitest-runner": "9.6.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
