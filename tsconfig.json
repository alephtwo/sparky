{
  "include": ["src", "vite.config.mts", "vitest.setup.mts"],
  "compilerOptions": {
    "types": ["vite/client", "@testing-library/jest-dom", "solid-js"],
    "lib": ["dom", "es2023"],
    "target": "es2022",
    "sourceMap": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "resolveJsonModule": true,
    "strict": true,
    "allowImportingTsExtensions": true
  }
}
